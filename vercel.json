{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/index.html", "headers": { "cache-control": "no-store" } },
    { "src": "/supervisor.html", "headers": { "cache-control": "no-store" } },
    { "handle": "filesystem" },
    { "src": "/supervisor(.*)", "dest": "/supervisor.html" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
